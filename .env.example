# Copy to .env.local to override the committed .env defaults.
# This project runs fully offline — no API keys required.

# SQLite file path (relative to the prisma/ directory)
DATABASE_URL="file:./dev.db"

# iron-session sealing password — MUST be at least 32 characters.
# Generate a new one for production:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_PASSWORD="veda-dental-demo-dev-session-password-change-me-in-production"
