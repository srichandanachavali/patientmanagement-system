# ── .env.example
# Copy this file to .env.local (dev) or set these as Vercel environment variables (prod).
# NEVER commit real values to git.

# ── Database (Neon Postgres) ────────────────────────────────────────────────
# Get from: Neon dashboard → Project → Connection Details → Connection string
# Must use ?sslmode=require for Neon
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── Session encryption ───────────────────────────────────────────────────────
# Minimum 32 characters. Generate with: openssl rand -base64 32
# Used by iron-session to sign/encrypt the veda_session cookie.
SESSION_PASSWORD="replace-with-at-least-32-random-characters"

# ── Vercel Blob storage ──────────────────────────────────────────────────────
# Get from: Vercel dashboard → Storage → Blob → your store → .env.local button
# Required in production; omit in local dev (falls back to public/uploads/)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx"

# ── App URL ─────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
